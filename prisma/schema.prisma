generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Respondent {
  id              String    @id @default(cuid())
  respondentCode  String    @unique
  age             Int
  gender          Gender
  education       String?
  occupation      String?
  name            String?
  phone           String?
  city            String?
  state           String?
  country         String?
  language        Language  @default(EN)
  createdAt       DateTime  @default(now())

  sessions        Session[]

  @@index([respondentCode])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Language {
  EN
  HI
  MR
}

model Session {
  id              String    @id @default(cuid())
  respondentId    String
  respondent      Respondent @relation(fields: [respondentId], references: [id], onDelete: Cascade)
  practitionerName String   // Name of practitioner (no auth)

  status          SessionStatus @default(IN_PROGRESS)
  phase           AssessmentPhase @default(MPPI)  // Track current phase

  startedAt       DateTime   @default(now())
  completedAt     DateTime?
  lastActivityAt  DateTime   @default(now())

  currentSection  Int        @default(1)
  currentItem     Int        @default(1)  // 1-118 for MPPI, 1-7 for GAD-7

  itemResponses   ItemResponse[]
  gad7Response    GAD7Response?
  result          SessionResult?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([respondentId])
  @@index([status])
  @@index([phase])
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum AssessmentPhase {
  MPPI
  GAD7
  RESULTS
}

model ItemResponse {
  id            String    @id @default(cuid())
  sessionId     String
  session       Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  itemNumber    Int       // 1-118
  probe1Score   Int       // 0-4
  probe2Score   Int       // 0-4
  probe3Score   Int       // 0-4
  itemTotal     Int       // computed: sum of 3 probes, max 12

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([sessionId, itemNumber])
  @@index([sessionId])
}

model GAD7Response {
  id              String    @id @default(cuid())
  sessionId       String    @unique
  session         Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  item1Score      Int       // 0-3
  item2Score      Int       // 0-3
  item3Score      Int       // 0-3
  item4Score      Int       // 0-3
  item5Score      Int       // 0-3
  item6Score      Int       // 0-3
  item7Score      Int       // 0-3
  impairmentScore Int       // 0-3

  totalScore      Int       // computed
  severity        GAD7Severity

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum GAD7Severity {
  MINIMAL
  MILD
  MODERATE
  SEVERE
}

model SessionResult {
  id                    String    @id @default(cuid())
  sessionId             String    @unique
  session               Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // MPPI Results
  subtypeRawScores      Json      // { "BRAMHA": 120, "ARSHA": 84, ... }
  subtypeMaxScores      Json      // { "BRAMHA": 180, "ARSHA": 84, ... }
  subtypePercentages    Json      // { "BRAMHA": 66.7, "ARSHA": 100, ... }

  predominantPrakriti   String    // subtype code
  secondaryPrakriti     String    // subtype code
  primaryCategory       String    // SATTVIKA | RAJASIKA | TAMASIKA

  // GAD-7 Results
  gad7Total             Int
  gad7Severity          String
  gad7Impairment        String    // Not difficult / Somewhat / Very / Extremely

  computedAt            DateTime  @default(now())

  @@index([sessionId])
}

model Item {
  id                    String    @id @default(cuid())
  itemNumber            Int       @unique
  section               Int
  sectionName           String

  predictorSanskrit     String
  predictorDevanagari   String
  interpretation        String

  coreProbeEn           String?
  coreProbeHi           String?
  coreProbeMr           String?

  probe1QuestionEn      String?
  probe1QuestionHi      String?
  probe1QuestionMr      String?
  probe1Score0En        String?
  probe1Score1En        String?
  probe1Score2En        String?
  probe1Score3En        String?
  probe1Score4En        String?

  probe2QuestionEn      String?
  probe2QuestionHi      String?
  probe2QuestionMr      String?
  probe2Score0En        String?
  probe2Score1En        String?
  probe2Score2En        String?
  probe2Score3En        String?
  probe2Score4En        String?

  probe3QuestionEn      String?
  probe3QuestionHi      String?
  probe3QuestionMr      String?
  probe3Score0En        String?
  probe3Score1En        String?
  probe3Score2En        String?
  probe3Score3En        String?
  probe3Score4En        String?

  mappedSubtypes        String[]  // ["BRAMHA", "YAAMYA"]
  isObserverRated       Boolean   @default(false)
  section14GenderVariant String?   // "male" | "female" | null
  reverseScored         Boolean   @default(false)

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([itemNumber])
  @@index([section])
}

model GAD7Item {
  id                String    @id @default(cuid())
  itemNumber        Int       @unique

  questionEn        String
  questionHi        String
  questionMr        String

  option0En         String
  option0Hi         String
  option0Mr         String
  option0Score      Int       @default(0)

  option1En         String
  option1Hi         String
  option1Mr         String
  option1Score      Int       @default(1)

  option2En         String
  option2Hi         String
  option2Mr         String
  option2Score      Int       @default(2)

  option3En         String
  option3Hi         String
  option3Mr         String
  option3Score      Int       @default(3)

  isImpairmentItem  Boolean   @default(false)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model SubtypeConfig {
  id                String    @id @default(cuid())
  subtypeCode       String    @unique
  fullName          String
  category          String    // SATTVIKA | RAJASIKA | TAMASIKA
  totalItems        Int
  maxScore          Int       // totalItems * 12

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}
